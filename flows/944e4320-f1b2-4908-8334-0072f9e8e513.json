          "4": {
            "id": 4,
            "name": "code",
            "data": {
              "label": "Load Persona",
              "code": "import json, os\n\npersona_path = os.path.join('assistant', 'persona.json')\nif os.path.exists(persona_path):\n    with open(persona_path, 'r') as f:\n        persona = json.load(f)\nelse:\n    persona = {\"name\":\"Atlas\",\"personality\":{\"core_traits\":[],\"speaking_style\":\"\",\"values\":\"\",\"quirks\":[]},\"relationship_notes\":[],\"conversation_count\":0}\n\npersona['conversation_count'] = persona.get('conversation_count', 0) + 1\nwith open(persona_path, 'w') as f:\n    json.dump(persona, f, indent=2)\n\ntry:\n    recent_history = json.loads(input_data)\nexcept:\n    recent_history = input_data\n\np = persona.get('personality', {})\ntraits = \"Core traits: \" + \", \".join(p.get('core_traits', []))\ntraits += \"\\nSpeaking style: \" + p.get('speaking_style', '')\ntraits += \"\\nValues: \" + p.get('values', '')\nif p.get('quirks'):\n    traits += \"\\nQuirks: \" + \", \".join(p.get('quirks', []))\n\nnotes = persona.get('relationship_notes', [])\nrel_notes = \"\\n\".join(f\"- {n}\" for n in notes) if notes else \"(New relationship \u2014 no notes yet)\"\n\nif isinstance(recent_history, list):\n    turns = []\n    for msg in recent_history[-10:]:\n        role = msg.get('role', '?')\n        content = msg.get('content', '')[:400]\n        turns.append(f\"{role}: {content}\")\n    recent_turns = \"\\n\".join(turns)\n    user_message = \"\"\n    for msg in reversed(recent_history):\n        if msg.get('role') == 'user':\n            user_message = msg.get('content', '')\n            break\nelse:\n    recent_turns = str(recent_history)[:1500]\n    user_message = recent_turns\n\noutput = json.dumps({\n    \"persona_traits\": traits,\n    \"relationship_notes\": rel_notes,\n    \"recent_turns\": recent_turns,\n    \"user_message\": user_message,\n    \"conversation_number\": persona['conversation_count']\n})"
            },
            "class": "node-code",
