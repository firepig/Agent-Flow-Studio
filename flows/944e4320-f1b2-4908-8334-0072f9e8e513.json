          "9": {
            "id": 9,
            "name": "code",
            "data": {
              "label": "Parse & Persist",
              "code": "import json, os, re\nfrom datetime import datetime\n\nresponse = ''\ninsight = ''\nnote = ''\n\nresp_match = re.search(r'<response>(.*?)</response>', input_data, re.DOTALL)\ninsight_match = re.search(r'<insight>(.*?)</insight>', input_data, re.DOTALL)\nnote_match = re.search(r'<note>(.*?)</note>', input_data, re.DOTALL)\n\nif resp_match:\n    response = resp_match.group(1).strip()\nif insight_match:\n    insight = insight_match.group(1).strip()\nif note_match:\n    note = note_match.group(1).strip()\n\nif not response:\n    cleaned = re.sub(r'<[^>]+>.*?</[^>]+>', '', input_data, flags=re.DOTALL).strip()\n    response = cleaned if cleaned else input_data.strip()\n\n# Filter out empty/placeholder insights\nif insight and insight.lower() in ('', 'empty', 'none', 'n/a', '(optional: a crystallized realization worth storing permanently, or leave empty)'):\n    insight = ''\n\n# Save to thought journal (full transcript, never embedded)\njournal_path = os.path.join('assistant', 'thought_journal.jsonl')\nos.makedirs('assistant', exist_ok=True)\nwith open(journal_path, 'a', encoding='utf-8') as f:\n    entry = {\n        \"timestamp\": datetime.now().isoformat(),\n        \"raw_llm_output\": input_data[:2000],\n        \"response\": response[:500],\n        \"insight\": insight,\n        \"note\": note\n    }\n    f.write(json.dumps(entry) + '\\n')\n\n# Update persona with relationship note\npersona_path = os.path.join('assistant', 'persona.json')\nif note and os.path.exists(persona_path):\n    with open(persona_path, 'r') as f:\n        persona = json.load(f)\n    notes = persona.get('relationship_notes', [])\n    if note not in notes:\n        notes.append(note)\n        if len(notes) > 20:\n            notes = notes[-20:]\n    persona['relationship_notes'] = notes\n    with open(persona_path, 'w') as f:\n        json.dump(persona, f, indent=2)\n\n# Output: clean response + flags for downstream routing\noutput = json.dumps({\n    \"response\": response,\n    \"insight\": insight,\n    \"note\": note,\n    \"has_insight\": bool(insight)\n})"
            },
