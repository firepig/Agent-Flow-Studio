            "data": {
              "label": "Format Report",
              "code": "lines = input_data.strip().split(\"\\n\")\nparts = [l.strip() for l in lines if l.strip()]\nreport = \"# System Report\\n\\n\"\nif len(parts) >= 3:\n    report += f\"- **OS:** {parts[0]}\\n\"\n    report += f\"- **CPU:** {parts[1]}\\n\"\n    report += f\"- **RAM:** {parts[2]}\\n\"\nelse:\n    for i, p in enumerate(parts):\n        report += f\"- {p}\\n\"\noutput = report",
              "unrestricted": false
