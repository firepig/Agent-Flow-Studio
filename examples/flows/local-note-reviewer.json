{
  "id": "local-note-reviewer",
  "name": "Local Note Reviewer",
  "description": "Read a local file, generate a structured review, and save the result to disk.",
  "complexity": "simple",
  "use_case": "Shows file I/O with an LLM in a practical documentation workflow.",
  "modules": ["start", "file_read", "prompt_template", "llm", "file_write", "output"],
  "flow_graph": {
    "nodes": [
      {
        "id": "1",
        "type": "start",
        "x": 80,
        "y": 200,
        "data": {
          "label": "Target File",
          "input_text": "README.md"
        }
      },
      {
        "id": "2",
        "type": "file_read",
        "x": 320,
        "y": 200,
        "data": {
          "label": "Read Note",
          "file_path_template": "{{input}}"
        }
      },
      {
        "id": "3",
        "type": "prompt_template",
        "x": 580,
        "y": 200,
        "data": {
          "label": "Review Prompt",
          "template": "Review the following local note or document.\\n\\nReturn markdown with these sections:\\n- Summary\\n- Strong points\\n- Gaps or ambiguities\\n- Suggested next edits\\n\\nDocument:\\n{{input}}"
        }
      },
      {
        "id": "4",
        "type": "llm",
        "x": 860,
        "y": 200,
        "data": {
          "label": "Reviewer",
          "provider": "",
          "model": "",
          "system_prompt": "You are an editorial reviewer. Be specific, concise, and actionable.",
          "user_prompt_template": "{{input}}",
          "temperature": 0.2,
          "max_tokens": 900
        }
      },
      {
        "id": "5",
        "type": "file_write",
        "x": 1120,
        "y": 200,
        "data": {
          "label": "Save Review",
          "file_path": "output/local-note-review.md",
          "write_mode": "write"
        }
      },
      {
        "id": "6",
        "type": "output",
        "x": 1360,
        "y": 200,
        "data": {
          "label": "Review Output",
          "output_name": "review_markdown"
        }
      }
    ],
    "connections": [
      { "from_node": "1", "from_output": "output_1", "to_node": "2", "to_input": "input_1" },
      { "from_node": "2", "from_output": "output_1", "to_node": "3", "to_input": "input_1" },
      { "from_node": "3", "from_output": "output_1", "to_node": "4", "to_input": "input_1" },
      { "from_node": "4", "from_output": "output_1", "to_node": "5", "to_input": "input_1" },
      { "from_node": "5", "from_output": "output_1", "to_node": "6", "to_input": "input_1" }
    ]
  }
}
