{
  "id": "iterative-headline-polisher",
  "name": "Iterative Headline Polisher",
  "description": "Rewrite a long launch message until it becomes a punchy, short headline.",
  "complexity": "simple",
  "use_case": "Demonstrates loop nodes with an LLM-based refinement cycle and success/fallback outputs.",
  "modules": ["start", "loop", "output"],
  "flow_graph": {
    "nodes": [
      {
        "id": "1",
        "type": "start",
        "x": 80,
        "y": 220,
        "data": {
          "label": "Long Draft",
          "input_text": "Ship our major agent flow studio productivity upgrade to every team this week."
        }
      },
      {
        "id": "2",
        "type": "loop",
        "x": 380,
        "y": 220,
        "data": {
          "label": "Polish Headline",
          "loop_mode": "llm",
          "max_iterations": 4,
          "condition_type": "regex",
          "condition_value": "^(\\\\S+\\\\s+){0,6}\\\\S+$",
          "loop_provider": "",
          "loop_model": "",
          "loop_system_prompt": "Rewrite the text into a sharper launch headline under seven words. Output only the headline.",
          "loop_user_template": "{{input}}",
          "loop_temperature": 0.3,
          "loop_max_tokens": 60,
          "loop_delay_ms": 0
        }
      },
      {
        "id": "3",
        "type": "output",
        "x": 700,
        "y": 150,
        "data": {
          "label": "Ready Headline",
          "output_name": "ready_headline"
        }
      },
      {
        "id": "4",
        "type": "output",
        "x": 700,
        "y": 290,
        "data": {
          "label": "Needs Revision",
          "output_name": "needs_revision"
        }
      }
    ],
    "connections": [
      { "from_node": "1", "from_output": "output_1", "to_node": "2", "to_input": "input_1" },
      { "from_node": "2", "from_output": "output_1", "to_node": "3", "to_input": "input_1" },
      { "from_node": "2", "from_output": "output_2", "to_node": "4", "to_input": "input_1" }
    ]
  }
}
